{
  "name": "@scribegate/client",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client for the Scribegate API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "openapi-ts --input ../openapi.json --output src/generated --client fetch",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
